<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.book.mappers.MemberMapper">

    <insert id="insertMember">
        INSERT INTO test_member (name, age, email)
        VALUES (#{name}, #{age}, #{email})
    </insert>

    <select id="selectAllMembers" resultType="com.book.Entity.MemberDTO">
        SELECT * FROM test_member ORDER BY id DESC
    </select>

</mapper>
